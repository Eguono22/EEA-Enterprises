{
  "expo": {
    "name": "EEA Enterprises",
    "slug": "eea-enterprises",
    "description": "Official EEA Enterprises mobile app for browsing eea-enterprises.com in a native shell.",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eea-enterprises",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3c5e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eeaenterprises.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a3c5e"
      },
      "package": "com.eeaenterprises.app",
      "versionCode": 6
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e34cb415-d71f-4ff0-86e0-3de57d85c0c4"
      }
    },
    "owner": "eguono22",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e34cb415-d71f-4ff0-86e0-3de57d85c0c4"
    }
  }
}
