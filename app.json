{
  "expo": {
    "name": "EEA Enterprises",
    "slug": "eea-enterprises",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eea-enterprises",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3c5e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eeaenterprises.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app does not use the camera.",
        "NSLocationWhenInUseUsageDescription": "This app does not use your location.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a3c5e"
      },
      "package": "com.eeaenterprises.app",
      "versionCode": 6
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e34cb415-d71f-4ff0-86e0-3de57d85c0c4"
      }
    },
    "owner": "eguono22",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e34cb415-d71f-4ff0-86e0-3de57d85c0c4"
    }
  }
}
